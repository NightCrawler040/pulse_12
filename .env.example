# Pulse 12 Environment Configuration Example
# Скопируйте этот файл в .env на сервере и задайте собственные значения

PORT=3001
NODE_ENV=production

# База данных PostgreSQL (если не указана, используется файловая база данных JSON)
DATABASE_URL=postgres://pulse12_user:<YOUR_DB_PASSWORD>@db:5432/pulse12

# Начальные учетные данные администратора (при инициализации чистой базы)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=<YOUR_ADMIN_PASSWORD>
ADMIN_PIN=<YOUR_ADMIN_PIN>

# Настройки CORS
CORS_ORIGIN=*

# Telegram Бот для уведомлений и Cron алертов
TELEGRAM_BOT_TOKEN=<YOUR_BOT_TOKEN_HERE>
TELEGRAM_CHAT_ID=<YOUR_CHAT_ID_HERE>

# SMTP Сервер для отправки Email-уведомлений
SMTP_HOST=<YOUR_SMTP_HOST_HERE>
SMTP_PORT=587
SMTP_USER=<YOUR_SMTP_USER_HERE>
SMTP_PASS=<YOUR_SMTP_PASS_HERE>
SMTP_FROM=Pulse 12 <no-reply@pulse12.lan>
